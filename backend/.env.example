# AI JD简历适配系统 环境配置模板
# 复制此文件为 .env 后修改

DATABASE_URL=sqlite:///./data/jd_resume.db

# LLM 供应商: ollama 或 deepseek
LLM_PROVIDER=deepseek

# Ollama 配置（本地部署）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# DeepSeek 配置（在线API）
# 在 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=这里填你的DeepSeek API Key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

DEBUG=True

# Boss 直聘风控配置
BOSS_DELIVERY_LIMIT=25
BOSS_MIN_INTERVAL=15
BOSS_MAX_INTERVAL=40
